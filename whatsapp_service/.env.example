# ─── WhatsApp Cloud API ────────────────────────────────────────────────────────
WA_API_VERSION=v21.0
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=spj_pos_webhook_2025

# ─── Internal auth (ERP → microservice notify endpoints) ──────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WA_INTERNAL_API_KEY=change_me_generate_a_strong_key

# ─── ERP DB Path ───────────────────────────────────────────────────────────────
# Path to the SQLite database relative to repo root, or absolute.
# Default resolves to: <repo>/pos_spj_v13.4/pos_spj_v13.4/spj_pos_database.db
ERP_DB_PATH=../pos_spj_v13.4/pos_spj_v13.4/spj_pos_database.db

# ─── ERP REST API (optional — enables write-through use cases) ────────────────
# When set, bridge.py will use REST for writes instead of direct SQLite.
ERP_API_URL=
ERP_API_KEY=

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── Rate limiting ────────────────────────────────────────────────────────────
MAX_MESSAGES_PER_MINUTE=15
MAX_FAILED_INTENTS=3

# ─── Conversaciones ───────────────────────────────────────────────────────────
CONVERSATION_TIMEOUT_MINUTES=30

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Ollama / DeepSeek local (Nivel 3 NLP — $0) ───────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT=15.0
