# WhatsApp Cloud API
WA_API_VERSION=v21.0
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=spj_pos_webhook_2025
WA_APP_SECRET=your_meta_app_secret

# ERP
ERP_DB_PATH=../pos_spj_v13.4/spj_pos_database.db

# MercadoPago (opcional)
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Rate limiting
MAX_MESSAGES_PER_MINUTE=15
MAX_FAILED_INTENTS=3

# Conversaciones
CONVERSATION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=INFO

# Ollama / DeepSeek local (Nivel 3 NLP — $0)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_TIMEOUT=15.0

# Internal API security (for /api/notify/* endpoints)
INTERNAL_API_KEY=change_me_in_production

# ERP REST API (optional — used for write operations instead of direct SQLite)
ERP_API_URL=
ERP_API_KEY=
